{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique ID of the user" },
        "email": { "type": "string", "format": "email", "description": "Email of the user" },
        "role": { "type": "string", "enum": ["admin", "customer"], "description": "Role of the user" },
        "name": { "type": "string", "description": "Name of the user" },
        "savedOutfits": { "type": "array", "items": { "type": "string" }, "description": "Array of saved outfit IDs" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "A product in the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the product" },
        "name": { "type": "string", "description": "Name of the product" },
        "category": { "type": "string", "description": "Category of the product" },
        "events": { "type": "array", "items": { "type": "string" }, "description": "Events the product is suitable for" },
        "price": { "type": "number", "description": "Price of the product" },
        "sizes": { "type": "array", "items": { "type": "string" }, "description": "Available sizes" },
        "fabric": { "type": "string", "description": "Fabric of the product" },
        "colors": { "type": "array", "items": { "type": "string" }, "description": "Available colors" },
        "description": { "type": "string", "description": "Description of the product" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "Array of image URLs" },
        "video": { "type": "string", "description": "Optional video URL" },
        "suggestedAccessories": { "type": "array", "items": { "type": "string" }, "description": "IDs of suggested accessories" },
        "featured": { "type": "boolean", "description": "Whether the product is featured" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["id", "name", "category", "price", "description", "fabric", "sizes", "colors", "images", "createdAt"]
    },
    "GalleryPost": {
      "title": "Gallery Post",
      "description": "A post in the Real Grooms Gallery.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the post" },
        "groomName": { "type": "string", "description": "Name of the groom" },
        "weddingDate": { "type": "string", "format": "date", "description": "Date of the wedding" },
        "outfitCategory": { "type": "string", "description": "Category of the outfit" },
        "caption": { "type": "string", "description": "Caption or message" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "Array of image URLs" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" },
        "approved": { "type": "boolean", "description": "Whether the post is approved by admin" },
        "authorUid": { "type": "string", "description": "UID of the user who created the post" }
      },
      "required": ["id", "groomName", "weddingDate", "outfitCategory", "caption", "images", "createdAt", "approved", "authorUid"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles and roles."
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Stores all products."
    },
    "gallery_posts/{postId}": {
      "schema": "GalleryPost",
      "description": "Stores all gallery posts submitted by users."
    }
  }
}
